<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= product.name %> | Ariatech Computers</title>
  <link rel="stylesheet" href="/css/common.css" />
  <link rel="stylesheet" href="/css/store.css" />
</head>
<body class="theme-light">
  <header class="top-nav">
    <div class="nav-left">
      <a href="/" class="logo">Ariatech</a>
    </div>
    <div class="nav-center" id="searchCenter">
      <form class="search-bar" action="/" method="get">
        <select name="category" class="search-category">
          <option value="all">All</option>
          <option value="computer-parts">Computer Parts</option>
          <option value="computer">Computer</option>
          <option value="peripherals">Peripherals</option>
          <option value="storage">Storage</option>
          <option value="games-and-hobbies">Games and Hobbies</option>
          <option value="network">Network</option>
          <option value="office-supplies">Office Supplies</option>
          <option value="software">Software</option>
          <option value="accessory">Accessory</option>
        </select>
        <input type="text" name="q" placeholder="Search Ariatech computers" class="search-input" />
        <button class="search-button" type="submit">Search</button>
      </form>
    </div>
    <div class="nav-right">
      <button class="search-toggle" id="searchToggle" aria-label="Toggle search">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
      <a href="/admin" class="nav-link">Admin</a>
    </div>
  </header>

  <main class="product-detail-layout">
    <div class="detail-image">
      <img src="<%= product.image_url || '/images/placeholder-laptop.jpg' %>" alt="<%= product.name %>" />
    </div>
    <div class="detail-info">
      <h1><%= product.name %></h1>
      <% if (product.brand) { %>
        <p class="detail-brand">Brand: <strong><%= product.brand %></strong></p>
      <% } %>
      <% if (product.category) { %>
        <p class="detail-category">Category: <%= product.category %></p>
      <% } %>
      <p class="detail-price">$<%= product.price.toFixed(2) %></p>
      <% if (product.description) { %>
        <p class="detail-description"><%= product.description %></p>
      <% } %>
  
    </div>
  </main>

  <% if (relatedProducts && relatedProducts.length > 0) { %>
  <section class="related-products">
    <h2>More from <%= product.category %></h2>
    <div class="related-products-slider">
      <% relatedProducts.forEach(function(relatedProduct) { %>
        <article class="product-card">
          <a href="/product/<%= relatedProduct.id %>">
            <div class="product-image-wrapper">
              <img src="<%= relatedProduct.image_url || '/images/placeholder-laptop.jpg' %>" alt="<%= relatedProduct.name %>" />
            </div>
            <div class="product-info">
              <h3 class="product-title"><%= relatedProduct.name %></h3>
              <% if (relatedProduct.brand) { %>
                <p class="product-brand"><%= relatedProduct.brand %></p>
              <% } %>
              <p class="product-price">$<%= relatedProduct.price.toFixed(2) %></p>
            </div>
          </a>
          <a href="/product/<%= relatedProduct.id %>" class="btn-secondary">Learn more</a>
        </article>
      <% }); %>
    </div>
  </section>
  <% } %>

  <footer class="site-footer">
    <div class="footer-bottom">
      <span>© <%= new Date().getFullYear() %> Ariatech Computers</span>
    </div>
  </footer>
  <script>
    document.getElementById('searchToggle').addEventListener('click', function() {
      document.getElementById('searchCenter').classList.toggle('active');
    });
  </script>
</body>
</html>
